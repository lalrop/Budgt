<style>
/* =====================================================
   VARIABLES — paleta rose/mauve para TIS
   ===================================================== */
:root {
  --tis-rose:      #c4748a;
  --tis-rose-lt:   #d9a0b0;
  --tis-rose-dim:  rgba(196, 116, 138, 0.12);
  --tis-rose-faint:rgba(196, 116, 138, 0.06);
  --tis-gold:      #c9a882;
}

/* =====================================================
   HERO
   ===================================================== */
.tis-hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 7rem 2.5rem 4rem;
  position: relative;
  overflow: hidden;
}

.tis-hero::before {
  content: '';
  position: absolute;
  top: -20%;
  right: -10%;
  width: 60vw;
  height: 60vw;
  border-radius: 50%;
  background: radial-gradient(circle, var(--tis-rose-dim) 0%, transparent 70%);
  pointer-events: none;
}

.tis-hero-tag {
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--tis-rose);
  border: 1px solid rgba(196, 116, 138, 0.35);
  padding: 0.35rem 0.9rem;
  margin-bottom: 2.2rem;
  width: fit-content;
}

.tis-hero h1 {
  font-family: var(--font-serif);
  font-size: clamp(2.8rem, 7vw, 5.5rem);
  line-height: 1.05;
  letter-spacing: -0.03em;
  max-width: 900px;
  margin-bottom: 1.8rem;
}

.tis-hero h1 em { font-style: italic; color: var(--gray-400); }

.tis-hero-sub {
  font-size: clamp(1rem, 2vw, 1.2rem);
  color: var(--gray-400);
  max-width: 580px;
  line-height: 1.72;
  margin-bottom: 2.5rem;
  font-weight: 300;
}

.tis-hero-actions {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

.tis-hero-badges { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
.tis-badge { font-size: 0.78rem; color: var(--gray-500); }
.tis-badge-sep { color: var(--gray-700); }

.hero-scroll {
  position: absolute;
  bottom: 2rem;
  left: 2.5rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  color: var(--gray-600);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}

.scroll-line {
  width: 40px;
  height: 1px;
  background: var(--gray-600);
  animation: scrollLine 2s ease-in-out infinite;
}

@keyframes scrollLine {
  0%, 100% { transform: scaleX(1); opacity: 1; }
  50%       { transform: scaleX(0.4); opacity: 0.4; }
}

/* =====================================================
   BOTONES
   ===================================================== */
.tis-btn-wa {
  display: inline-flex;
  align-items: center;
  gap: 0.7rem;
  background: var(--wa-green);
  color: var(--white);
  font-family: var(--font-sans);
  font-weight: 600;
  font-size: 0.95rem;
  padding: 0.9rem 2rem;
  text-decoration: none;
  transition: opacity 0.2s;
}
.tis-btn-wa:hover { opacity: 0.88; }
.tis-btn-wa--large { font-size: 1.05rem; padding: 1.1rem 2.6rem; margin-bottom: 1.2rem; }

.tis-btn-ghost {
  color: var(--gray-400);
  font-size: 0.9rem;
  text-decoration: none;
  transition: color 0.2s;
}
.tis-btn-ghost:hover { color: var(--white); }

.tis-btn-servicio {
  display: inline-block;
  padding: 0.75rem 1.8rem;
  border: 1px solid var(--gray-700);
  color: var(--white);
  font-size: 0.88rem;
  font-weight: 500;
  text-decoration: none;
  transition: border-color 0.2s, color 0.2s;
  margin-top: 1.2rem;
}
.tis-btn-servicio:hover { border-color: var(--tis-rose); color: var(--tis-rose); }

/* =====================================================
   TRUST BAR
   ===================================================== */
.tis-trust-bar {
  background: var(--gray-900);
  border-top: 1px solid var(--gray-800);
  border-bottom: 1px solid var(--gray-800);
  padding: 1rem 2.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  flex-wrap: wrap;
}
.trust-item { font-size: 0.82rem; color: var(--gray-400); }
.trust-sep  { color: var(--gray-700); }

/* =====================================================
   SECCIONES
   ===================================================== */
.tis-section { padding: 7rem 2.5rem; }
.tis-section--dark {
  background: var(--gray-900);
  border-top: 1px solid var(--gray-800);
  border-bottom: 1px solid var(--gray-800);
}
.tis-container         { max-width: 1100px; margin: 0 auto; }
.tis-container--narrow { max-width: 760px; }

.tis-section h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 3.5rem;
}
.tis-section h2 em { font-style: italic; color: var(--gray-500); }

/* =====================================================
   PROBLEMAS
   ===================================================== */
.problemas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1px;
  background: var(--gray-800);
}

.problema-card {
  background: var(--black);
  padding: 2rem 1.8rem;
  transition: background 0.2s;
  border-top: 2px solid transparent;
  transition: background 0.2s, border-color 0.2s;
}
.problema-card:hover { background: var(--gray-900); border-top-color: var(--tis-rose); }
.problema-icon { font-size: 1.4rem; margin-bottom: 1rem; }
.problema-card h3 {
  font-family: var(--font-sans);
  font-size: 0.95rem;
  font-weight: 600;
  letter-spacing: 0;
  line-height: 1.3;
  margin-bottom: 0.8rem;
  color: var(--white);
}
.problema-card p { font-size: 0.85rem; color: var(--gray-500); line-height: 1.75; font-weight: 300; }

/* =====================================================
   SERVICIOS — layout con mockup
   ===================================================== */
.servicio-block {
  border-top: 1px solid var(--gray-800);
  padding: 4rem 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
.servicio-block:last-child { border-bottom: 1px solid var(--gray-800); }

.servicio-content { display: flex; flex-direction: column; }

.servicio-header {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
  margin-bottom: 1.5rem;
}
.servicio-num {
  font-family: var(--font-serif);
  font-size: 1.8rem;
  color: var(--tis-rose);
  opacity: 0.4;
  flex-shrink: 0;
  line-height: 1;
  margin-top: 0.2rem;
  min-width: 2.2rem;
}
.servicio-header h3 {
  font-family: var(--font-sans);
  font-size: 1.1rem;
  font-weight: 600;
  letter-spacing: 0;
  line-height: 1.3;
  margin-bottom: 0.5rem;
  color: var(--white);
}
.servicio-desc { font-size: 0.9rem; color: var(--gray-400); line-height: 1.7; font-weight: 300; }

.servicio-bullets {
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
  margin-bottom: 1.5rem;
  padding-left: 0.2rem;
}
.servicio-bullets li {
  font-size: 0.88rem;
  color: var(--gray-400);
  line-height: 1.55;
  font-weight: 300;
  padding-left: 1.3rem;
  position: relative;
}
.servicio-bullets li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--tis-rose);
  font-size: 0.8rem;
}

.servicio-testimonio {
  border-left: 2px solid var(--tis-rose);
  padding-left: 1rem;
  margin-bottom: 0;
}
.servicio-testimonio p {
  font-size: 0.85rem;
  color: var(--gray-400);
  font-style: italic;
  line-height: 1.65;
  margin-bottom: 0.3rem;
}
.testimonio-meta { font-size: 0.75rem; color: var(--gray-600); font-style: normal; }

/* =====================================================
   MOCKUP BASE
   ===================================================== */
.servicio-mockup {
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ——— Mockup 01: WhatsApp ——— */
.mock-phone {
  width: 100%;
  max-width: 310px;
  border: 1px solid var(--gray-800);
  border-radius: 2px;
  overflow: hidden;
  background: #111;
  box-shadow: 0 0 40px var(--tis-rose-dim);
}

.mock-wa-header {
  background: #1a1a2e;
  padding: 0.8rem 1rem;
  display: flex;
  align-items: center;
  gap: 0.7rem;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.mock-wa-avatar {
  width: 34px; height: 34px;
  border-radius: 50%;
  background: var(--tis-rose-dim);
  border: 1px solid var(--tis-rose);
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem; flex-shrink: 0;
}
.mock-wa-info { flex: 1; }
.mock-wa-name  { font-size: 0.82rem; font-weight: 600; color: var(--white); }
.mock-wa-status{ font-size: 0.7rem; color: #4ade80; }
.mock-wa-lock  { font-size: 0.75rem; color: var(--gray-700); }

.mock-wa-body {
  padding: 1rem;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
  background: #0d0d1a;
  min-height: 240px;
}

.mock-bubble {
  padding: 0.55rem 0.8rem;
  border-radius: 4px;
  font-size: 0.78rem;
  line-height: 1.45;
  max-width: 85%;
}
.mock-bubble--in {
  background: var(--gray-800);
  color: var(--gray-300);
  align-self: flex-start;
}
.mock-bubble--out {
  background: rgba(196, 116, 138, 0.18);
  border: 1px solid rgba(196, 116, 138, 0.25);
  color: var(--gray-200);
  align-self: flex-end;
  text-align: right;
}
.mock-ts {
  display: block;
  font-size: 0.65rem;
  color: var(--tis-rose);
  margin-top: 0.3rem;
}

/* ——— Mockup 02: Marca personal ——— */
.mock-brand {
  width: 100%;
  max-width: 320px;
  border: 1px solid var(--gray-800);
  overflow: hidden;
  background: #0f0f0f;
  box-shadow: 0 0 40px var(--tis-rose-dim);
}
.mock-banner-bg {
  height: 80px;
  background: linear-gradient(135deg, #2a1020 0%, #1a0a2a 50%, #200a1a 100%);
  position: relative;
}
.mock-banner-bg::after {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    45deg,
    rgba(196,116,138,0.07) 0px, rgba(196,116,138,0.07) 1px,
    transparent 1px, transparent 14px
  );
}
.mock-brand-body { padding: 0 1rem 1rem; }
.mock-avatar-wrap { margin-top: -22px; margin-bottom: 0.5rem; }
.mock-avatar-ring {
  width: 44px; height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--tis-rose), var(--tis-gold));
  padding: 2px;
}
.mock-avatar-inner {
  width: 100%; height: 100%;
  border-radius: 50%;
  background: #0f0f0f;
  display: flex; align-items: center; justify-content: center;
  font-size: 1rem; color: var(--tis-rose);
}
.mock-brand-name { font-size: 0.82rem; font-weight: 600; color: var(--white); margin-bottom: 0.2rem; }
.mock-brand-bio  { font-size: 0.72rem; color: var(--gray-500); margin-bottom: 0.6rem; }
.mock-brand-stats {
  display: flex; gap: 1rem;
  font-size: 0.72rem; color: var(--gray-400);
  margin-bottom: 0.8rem;
  padding-bottom: 0.8rem;
  border-bottom: 1px solid var(--gray-800);
}
.mock-brand-stats strong { color: var(--white); }
.mock-posts-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
}
.mock-post { aspect-ratio: 1; border-radius: 1px; }
.mock-post--a { background: linear-gradient(135deg, #3a1a2a, #2a0a1a); }
.mock-post--b { background: linear-gradient(135deg, #1a1a3a, #0a0a2a); }
.mock-post--c { background: linear-gradient(135deg, #2a1a1a, #1a0a0a); }
.mock-post--d { background: linear-gradient(135deg, #1a2a2a, rgba(196,116,138,0.15)); }
.mock-post--e { background: linear-gradient(135deg, #2a1a3a, #1a0a2a); }
.mock-post--f { background: linear-gradient(135deg, #3a2a1a, #2a1a0a); }

/* ——— Mockup 03: Protección ——— */
.mock-protect-wrap {
  width: 100%;
  max-width: 320px;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.mock-protect-img {
  position: relative;
  height: 180px;
  overflow: hidden;
  border: 1px solid var(--gray-800);
  box-shadow: 0 0 40px var(--tis-rose-dim);
}
.mock-img-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #2a1020 0%, #200a1a 40%, #1a0a2a 100%);
}
.mock-watermark-grid {
  position: absolute;
  inset: 0;
  display: grid;
  grid-template-columns: repeat(3,1fr);
  grid-template-rows: repeat(3,1fr);
  align-items: center;
  justify-items: center;
  pointer-events: none;
}
.mock-wm-text {
  font-size: 0.58rem;
  color: rgba(255,255,255,0.18);
  transform: rotate(-30deg);
  white-space: nowrap;
  letter-spacing: 0.05em;
  font-weight: 500;
}
.mock-protect-badge {
  position: absolute;
  bottom: 0.6rem;
  right: 0.6rem;
  background: rgba(196,116,138,0.2);
  border: 1px solid var(--tis-rose);
  color: var(--tis-rose-lt);
  font-size: 0.68rem;
  padding: 0.25rem 0.6rem;
  font-weight: 500;
}
.mock-alert-strip {
  padding: 0.6rem 0.9rem;
  font-size: 0.75rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  border: 1px solid var(--gray-800);
  font-weight: 400;
}
.mock-alert-strip--warn { color: #f59e0b; background: rgba(245,158,11,0.06); }
.mock-alert-strip--ok   { color: #4ade80; background: rgba(74,222,128,0.06); }
.mock-alert-dot { width: 6px; height: 6px; border-radius: 50%; background: #f59e0b; flex-shrink: 0; }
.mock-alert-dot--ok { background: #4ade80; }

/* ——— Mockup 04: Videollamada ——— */
.mock-call {
  width: 100%;
  max-width: 320px;
  background: #0d0d1a;
  border: 1px solid var(--gray-800);
  overflow: hidden;
  box-shadow: 0 0 40px var(--tis-rose-dim);
}
.mock-call-screen {
  position: relative;
  height: 180px;
  background: #080814;
  display: flex;
  align-items: center;
  justify-content: center;
}
.mock-call-main {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}
.mock-call-avatar {
  width: 52px; height: 52px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-weight: 600; font-size: 1.1rem;
}
.mock-call-avatar--tutor {
  background: var(--tis-rose-dim);
  border: 2px solid var(--tis-rose);
  color: var(--tis-rose-lt);
}
.mock-call-avatar--self {
  background: var(--gray-800);
  border: 1px solid var(--gray-700);
  color: var(--gray-400);
  width: 36px; height: 36px; font-size: 0.7rem;
}
.mock-call-label {
  font-size: 0.68rem;
  color: var(--gray-500);
  text-align: center;
}
.mock-call-screenshare {
  width: 90px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--gray-800);
  padding: 0.4rem 0.5rem;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.mock-ss-bar {
  height: 3px;
  background: var(--gray-700);
  border-radius: 2px;
  width: 60%;
}
.mock-ss-bar--long { width: 100%; }
.mock-ss-bar--med  { width: 80%; }
.mock-call-self {
  position: absolute;
  bottom: 0.7rem;
  right: 0.7rem;
}
.mock-call-controls {
  padding: 0.8rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  border-top: 1px solid var(--gray-800);
}
.mock-ctrl {
  width: 34px; height: 34px;
  border-radius: 50%;
  background: var(--gray-800);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.85rem;
  cursor: default;
}
.mock-ctrl--hang {
  background: #dc2626;
  color: white;
  font-size: 0.75rem;
  font-weight: 700;
}
.mock-call-badge {
  text-align: center;
  font-size: 0.68rem;
  color: var(--gray-600);
  padding: 0.4rem;
  border-top: 1px solid var(--gray-800);
}

/* ——— Mockup 05: Plataforma ——— */
.mock-platform {
  width: 100%;
  max-width: 320px;
  border: 1px solid var(--gray-800);
  overflow: hidden;
  background: #0d0d0d;
  box-shadow: 0 0 40px var(--tis-rose-dim);
}
.mock-plat-cover {
  height: 70px;
  background: linear-gradient(135deg, #2a0a1a 0%, #1a0a2a 60%, #200a15 100%);
}
.mock-plat-body { padding: 0 1rem 1rem; }
.mock-plat-avatar {
  width: 42px; height: 42px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--tis-rose), var(--tis-gold));
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 1.1rem;
  color: var(--white);
  margin-top: -21px;
  margin-bottom: 0.5rem;
  border: 2px solid #0d0d0d;
}
.mock-plat-name { font-size: 0.82rem; font-weight: 600; color: var(--white); margin-bottom: 0.6rem; }
.mock-plat-stats {
  display: flex;
  gap: 0;
  margin-bottom: 0.8rem;
  padding-bottom: 0.8rem;
  border-bottom: 1px solid var(--gray-800);
}
.mock-plat-stat {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}
.mock-plat-stat strong { font-size: 0.95rem; color: var(--white); font-weight: 700; }
.mock-plat-stat span  { font-size: 0.65rem; color: var(--gray-500); }
.mock-plat-checks { display: flex; flex-direction: column; gap: 0.45rem; }
.mock-check { font-size: 0.72rem; color: var(--gray-400); }
.mock-check--done { color: #4ade80; }
.mock-check--done::before { content: ''; }

/* ——— Mockup 06: Dashboard ——— */
.mock-dashboard {
  width: 100%;
  max-width: 320px;
  background: #0d0d0d;
  border: 1px solid var(--gray-800);
  padding: 1.2rem;
  box-shadow: 0 0 40px var(--tis-rose-dim);
}
.mock-dash-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 1rem;
}
.mock-dash-title { font-size: 0.8rem; font-weight: 600; color: var(--white); }
.mock-dash-sub   { font-size: 0.68rem; color: var(--gray-600); margin-top: 0.1rem; }
.mock-dash-kpi   { font-family: var(--font-serif); font-size: 1.5rem; color: #4ade80; line-height: 1; }
.mock-dash-kpi span { font-size: 0.9rem; }

.mock-chart {
  display: flex;
  align-items: flex-end;
  gap: 4px;
  height: 100px;
  margin-bottom: 0.8rem;
  padding-bottom: 1.2rem;
  border-bottom: 1px solid var(--gray-800);
  position: relative;
}
.mock-bar-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  height: 100%;
  justify-content: flex-end;
}
.mock-bar {
  width: 100%;
  background: var(--gray-800);
  border-radius: 1px 1px 0 0;
  transition: background 0.2s;
}
.mock-bar--accent { background: var(--tis-rose) !important; }
.mock-bar-wrap span {
  font-size: 0.6rem;
  color: var(--gray-600);
  position: absolute;
  bottom: 0;
}
.mock-bar-wrap:nth-child(1) span { left: calc(0 * (100%/7) + 2px); }
.mock-bar-wrap:nth-child(2) span { left: calc(1 * (100%/7) + 2px); }
.mock-bar-wrap:nth-child(3) span { left: calc(2 * (100%/7) + 2px); }
.mock-bar-wrap:nth-child(4) span { left: calc(3 * (100%/7) + 2px); }
.mock-bar-wrap:nth-child(5) span { left: calc(4 * (100%/7) + 2px); }
.mock-bar-wrap:nth-child(6) span { left: calc(5 * (100%/7) + 2px); }
.mock-bar-wrap:nth-child(7) span { left: calc(6 * (100%/7) + 2px); }

.mock-dash-insight {
  font-size: 0.75rem;
  color: var(--tis-rose-lt);
  margin-bottom: 0.8rem;
  font-style: italic;
}
.mock-dash-tags { display: flex; gap: 0.4rem; flex-wrap: wrap; }
.mock-tag {
  font-size: 0.65rem;
  padding: 0.2rem 0.5rem;
  border: 1px solid rgba(196,116,138,0.3);
  color: var(--tis-rose-lt);
  background: var(--tis-rose-faint);
}

/* ——— Mockup 07: Página web ——— */
.mock-web {
  width: 100%;
  max-width: 320px;
  background: #090909;
  border: 1px solid var(--gray-800);
  overflow: hidden;
  font-size: 0.72rem;
  box-shadow: 0 0 40px var(--tis-rose-dim);
}
.mock-web-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.5rem 0.8rem;
  border-bottom: 1px solid var(--gray-800);
  background: rgba(255,255,255,0.02);
}
.mock-web-logo    { color: var(--tis-rose); font-weight: 600; letter-spacing: 0.05em; }
.mock-web-navbtn  { font-size: 0.65rem; border: 1px solid var(--tis-rose); color: var(--tis-rose); padding: 0.2rem 0.5rem; }

.mock-web-hero {
  padding: 0.8rem;
  background: linear-gradient(135deg, #150a12 0%, #0a0a18 100%);
  border-bottom: 1px solid var(--gray-800);
}
.mock-web-h1 { height: 8px; background: var(--gray-700); border-radius: 2px; margin-bottom: 5px; width: 70%; }
.mock-web-p  { height: 5px; background: var(--gray-800); border-radius: 2px; width: 50%; }

.mock-web-gallery {
  display: grid;
  grid-template-columns: 2fr 1fr;
  grid-template-rows: 60px 60px;
  gap: 2px;
  padding: 0.5rem;
}
.mock-web-img {
  background: var(--gray-800);
  position: relative;
  overflow: hidden;
  display: flex; align-items: flex-end; justify-content: flex-end;
  padding: 3px;
}
.mock-web-img--lg { grid-row: span 2; background: linear-gradient(135deg, #2a0a1a, #1a0a2a); }
.mock-web-img:not(.mock-web-img--lg) { background: linear-gradient(135deg, #1a0a1a, #120a1a); }
.mock-web-wm { font-size: 0.5rem; color: rgba(255,255,255,0.2); white-space: nowrap; }

.mock-web-cal { padding: 0.6rem 0.8rem 0.8rem; }
.mock-cal-title { font-size: 0.7rem; font-weight: 600; color: var(--gray-400); margin-bottom: 0.5rem; }
.mock-cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 2px;
}
.mock-cal-day {
  text-align: center;
  font-size: 0.55rem;
  color: var(--gray-600);
  padding: 2px 0;
  font-weight: 600;
}
.mock-cal-num {
  text-align: center;
  font-size: 0.6rem;
  color: var(--gray-600);
  padding: 3px 0;
  border-radius: 1px;
}
.mock-cal-num--avail { background: rgba(196,116,138,0.15); color: var(--tis-rose-lt); }
.mock-cal-num--taken { background: var(--gray-800); color: var(--gray-700); }
.mock-cal-legend {
  display: flex;
  gap: 0.8rem;
  margin-top: 0.4rem;
}
.mock-leg { font-size: 0.58rem; color: var(--gray-500); display: flex; align-items: center; gap: 0.3rem; }
.mock-leg::before { content: ''; width: 8px; height: 8px; border-radius: 1px; }
.mock-leg--avail::before { background: rgba(196,116,138,0.3); }
.mock-leg--taken::before { background: var(--gray-800); }

/* =====================================================
   CÓMO FUNCIONA
   ===================================================== */
.pasos-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1px;
  background: var(--gray-800);
}
.paso {
  background: var(--black);
  padding: 2.5rem 2rem;
  border-top: 2px solid transparent;
  transition: border-color 0.2s;
}
.paso:hover { border-top-color: var(--tis-rose); }
.paso-num { font-family: var(--font-serif); font-size: 3rem; color: var(--gray-800); line-height: 1; margin-bottom: 1.2rem; }
.paso h3  { font-family: var(--font-sans); font-size: 0.95rem; font-weight: 600; letter-spacing: 0; margin-bottom: 0.7rem; color: var(--white); }
.paso p   { font-size: 0.85rem; color: var(--gray-500); line-height: 1.75; font-weight: 300; }

/* =====================================================
   PLANES
   ===================================================== */
.planes-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--gray-800);
  margin-bottom: 1.5rem;
}

.plan-tis {
  background: var(--black);
  padding: 2.5rem 2rem;
  position: relative;
  display: flex;
  flex-direction: column;
  border-top: 2px solid transparent;
  transition: border-color 0.2s;
}
.plan-tis:hover { border-top-color: var(--tis-rose); }
.plan-tis--featured { background: var(--white); color: var(--black); border-top-color: var(--tis-rose) !important; }

.plan-tis-popular {
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--tis-rose);
  margin-bottom: 0.4rem;
}
.plan-tis-tag {
  font-family: var(--font-serif);
  font-size: 1.5rem;
  letter-spacing: -0.02em;
  margin-bottom: 1.2rem;
  color: var(--white);
}
.plan-tis--featured .plan-tis-tag { color: var(--black); }

.plan-tis-price { margin-bottom: 0.5rem; }
.plan-usd {
  display: block;
  font-family: var(--font-serif);
  font-size: 2rem;
  letter-spacing: -0.02em;
  line-height: 1;
  color: var(--white);
}
.plan-tis--featured .plan-usd { color: var(--black); }
.plan-period { font-size: 1rem; font-family: var(--font-sans); letter-spacing: 0; color: var(--gray-500); }
.plan-tis--featured .plan-period { color: #888; }
.plan-clp { display: block; font-size: 0.78rem; color: var(--gray-600); font-weight: 300; margin-top: 0.3rem; }
.plan-tis--featured .plan-clp { color: #888; }

.plan-tis-ideal {
  font-size: 0.78rem; color: var(--gray-600); margin-bottom: 1.5rem;
  padding-bottom: 1.5rem; border-bottom: 1px solid var(--gray-800);
  font-weight: 300; line-height: 1.4;
}
.plan-tis--featured .plan-tis-ideal { color: #777; border-color: #ddd; }

.plan-tis-features { display: flex; flex-direction: column; gap: 0.65rem; margin-bottom: 2rem; flex: 1; }
.plan-tis-features li { font-size: 0.82rem; font-weight: 300; padding-left: 1.4rem; position: relative; line-height: 1.45; }

.feat-yes { color: var(--gray-300); }
.feat-yes::before { content: '✓'; position: absolute; left: 0; color: var(--tis-rose); font-weight: 600; }
.plan-tis--featured .feat-yes { color: #333; }
.plan-tis--featured .feat-yes::before { color: #c4748a; }

.feat-no { color: var(--gray-700); }
.feat-no::before { content: '–'; position: absolute; left: 0; color: var(--gray-700); }
.plan-tis--featured .feat-no { color: #bbb; }
.plan-tis--featured .feat-no::before { color: #bbb; }

.plan-tis-btn {
  display: block;
  text-align: center;
  padding: 0.85rem;
  font-family: var(--font-sans);
  font-weight: 600;
  font-size: 0.85rem;
  text-decoration: none;
  border: 1px solid var(--gray-800);
  color: var(--white);
  transition: border-color 0.2s, color 0.2s, background 0.2s;
  letter-spacing: 0.02em;
}
.plan-tis-btn:hover { border-color: var(--tis-rose); color: var(--tis-rose); }
.plan-tis--featured .plan-tis-btn { background: var(--black); color: var(--white); border-color: var(--black); }
.plan-tis--featured .plan-tis-btn:hover { background: #2a1020; border-color: var(--tis-rose); color: var(--tis-rose); }

.plan-web { border: 1px solid var(--gray-800); margin-bottom: 2rem; }
.plan-web-inner {
  padding: 2rem 2.2rem;
  display: flex; justify-content: space-between; align-items: center;
  gap: 2rem; flex-wrap: wrap;
}
.plan-web-label { font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--tis-rose); margin-bottom: 0.5rem; font-weight: 500; }
.plan-web h3   { font-family: var(--font-sans); font-size: 1rem; font-weight: 600; letter-spacing: 0; margin-bottom: 0.4rem; color: var(--white); }
