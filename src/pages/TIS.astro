---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQItem from '../components/FAQItem.astro';
import { getWhatsAppUrl } from '../utils/constants';

const waGeneral     = getWhatsAppUrl('Hola, me interesa conocer los servicios de Budgt TIS para trabajadoras independientes.');
const waChatbot     = getWhatsAppUrl('Hola, me interesa el Chatbot WhatsApp 24/7 de Budgt TIS.');
const waMarca       = getWhatsAppUrl('Hola, me interesa el servicio de identidad visual y marca personal de Budgt TIS.');
const waProteccion  = getWhatsAppUrl('Hola, me interesa el servicio de protección de contenido y anti-piratería de Budgt TIS.');
const waCapacitacion= getWhatsAppUrl('Hola, me interesa una sesión de capacitación 1-a-1 con Budgt TIS.');
const waSetupPlat   = getWhatsAppUrl('Hola, me interesa el Setup inicial de plataformas (OnlyFans / Fansly / Privacy) de Budgt TIS.');
const waReportes    = getWhatsAppUrl('Hola, me interesa el servicio de reportería y análisis mensual de Budgt TIS.');
const waPagina      = getWhatsAppUrl('Hola, me interesa la página web con booking protegido de Budgt TIS.');
const waInicio      = getWhatsAppUrl('Hola, me interesa el Plan Inicio de Budgt TIS (~$50.000 CLP/mes).');
const waCrecimiento = getWhatsAppUrl('Hola, me interesa el Plan Crecimiento de Budgt TIS (~$259.000 CLP/mes). Es el más vendido.');
const waSetupUnico  = getWhatsAppUrl('Hola, me interesa el Plan Setup Único de Budgt TIS (~$499.000 CLP pago único).');
const waPremium     = getWhatsAppUrl('Hola, me interesa el Plan Premium de Budgt TIS (~$699.000 CLP/mes).');
const waWebBooking  = getWhatsAppUrl('Hola, me interesa agregar la página web con booking protegido de Budgt TIS ($450.000 CLP).');

const problemas = [
  { icon: '📱', titulo: 'El teléfono no para',       descripcion: 'Responder 200 veces al día cuánto cobras, dónde quedas y si atiendes hoy. Con el teléfono en la mano hasta la madrugada, sin poder desconectarte.' },
  { icon: '⏳', titulo: 'Clientes que no concretan', descripcion: 'Pierdes 2 horas diarias con personas que preguntan, preguntan, preguntan… y nunca reservan. Tiempo que no recuperas.' },
  { icon: '📷', titulo: 'Tu imagen no te representa',descripcion: 'Tienes foto de hace 3 años porque editar, publicar y mantener redes toma tiempo que no tienes — o energía que no te sobra.' },
  { icon: '🧠', titulo: 'Todo en tu cabeza',         descripcion: 'La agenda, los clientes fijos, los pagos pendientes, los follow-ups. Sin sistema. Sin ayuda. Solo tú y tu memoria.' },
  { icon: '🔓', titulo: 'El contenido que te roban', descripcion: 'Fotos tuyas circulando gratis en Telegram, foros o grupos. Sin tu permiso. Sin consecuencias para quien lo sube. Sin que nadie te avise.' },
  { icon: '📊', titulo: 'No sabes qué funciona',     descripcion: 'Publicas, contestas, trabajas… pero no tienes idea si tus precios están bien, qué días generan más reservas, o qué canal te trae clientes reales.' },
];

const faqs = [
  { question: '¿Cómo sé que mis datos están seguros?',           answer: 'Toda la comunicación va encriptada. No almacenamos fotos ni videos tuyos en nuestros servidores. Los accesos a tus plataformas los manejas tú — nosotros configuramos, tú controlas.' },
  { question: '¿Trabajan con chicas trans?',                     answer: 'Sí, con orgullo. Budgt TIS es un espacio para todas las trabajadoras independientes — cis, trans y no binaries. Sin excepciones.' },
  { question: '¿Aceptan clientas masculinas?',                   answer: 'Sí. El servicio está pensado para trabajadoras sexuales independientes de todos los géneros. Si trabajas de forma independiente, estás bienvenida/o/e.' },
  { question: '¿Puedo contratar solo un servicio?',              answer: 'Absolutamente. No tienes que tomar un paquete completo si no lo necesitas. Muchas clientas empiezan con un servicio y van sumando cuando están listas.' },
  { question: '¿Qué pasa si me arrepiento o quiero cancelar?',   answer: 'Sin lock-in, sin penalizaciones. Los planes mensuales los cancelas cuando quieras, avisándonos antes del siguiente ciclo. El setup único ya quedó hecho — es tuyo para siempre.' },
  { question: '¿Cómo es la primera conversación?',               answer: 'Por WhatsApp. Sin formularios, sin nombres reales si no quieres, sin preguntas incómodas. Tú marcas el ritmo.' },
  { question: '¿Trabajan con personas fuera de Santiago?',       answer: 'Sí, 100% remoto. Tenemos clientas en Santiago, Valparaíso, Concepción, Temuco y otras ciudades. Todo se hace por WhatsApp y videollamada.' },
  { question: '¿Cuánto tarda en estar listo el chatbot?',        answer: 'Entre 5 y 10 días hábiles desde que aprobás la configuración. Nada se activa sin tu visto bueno.' },
  { question: '¿Tienen experiencia con OnlyFans, Fansly y Privacy?', answer: 'Sí. Conocemos las particularidades de cada plataforma, sus algoritmos, sus restricciones y sus oportunidades. No empezamos de cero cada vez.' },
];
---

<BaseLayout
  title="Budgt TIS — Digitalización para trabajadoras independientes en Chile"
  description="Chatbot 24/7, marca personal, protección de contenido y más. Tecnología diseñada para trabajadoras sexuales independientes. Confidencial, sin juicios, 100% Chile."
  page="tis"
  canonical="https://budgt.cl/TIS"
  navLinks={[
    { text: 'Servicios',   href: '#servicios'   },
    { text: 'Planes',      href: '#planes'       },
    { text: 'Testimonios', href: '#testimonios'  },
    { text: 'FAQ',         href: '#faq'          },
  ]}
  navCtaText="Escribirnos →"
>

<!-- ==================== HERO ==================== -->
<section class="tis-hero">
  <div class="tis-hero-tag">Budgt TIS · Solo para independientes · 🇨🇱 Chile</div>
  <h1>Deja de responder<br /><em>lo mismo 200 veces al día.</em></h1>
  <p class="tis-hero-sub">
    Budgt TIS es la agencia chilena que digitaliza tu negocio independiente — chatbot con IA,
    marca personal, protección de contenido y mucho más. Sin juicios. Sin letra chica. 100% confidencial.
  </p>
  <div class="tis-hero-actions">
    <a href={waGeneral} class="tis-btn-wa" target="_blank" rel="noopener">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.558 4.167 1.618 5.955L.057 23.928a.5.5 0 0 0 .611.611l5.973-1.561A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.96 9.96 0 0 1-5.073-1.384l-.363-.215-3.763.984.984-3.763-.215-.363A9.96 9.96 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
      Hablar por WhatsApp
    </a>
    <a href="#planes" class="tis-btn-ghost">Ver planes y precios ↓</a>
  </div>
  <div class="tis-hero-badges">
    <span class="tis-badge">🇨🇱 Chile</span>
    <span class="tis-badge-sep">·</span>
    <span class="tis-badge">Sin juicios</span>
    <span class="tis-badge-sep">·</span>
    <span class="tis-badge">Confidencial</span>
    <span class="tis-badge-sep">·</span>
    <span class="tis-badge">24/7</span>
  </div>
  <div class="hero-scroll">
    <div class="scroll-line"></div>
    <span>Desplázate</span>
  </div>
</section>

<!-- ==================== TRUST BAR ==================== -->
<div class="tis-trust-bar">
  <div class="trust-item">🔒 Acceso privado · Solo por invitación</div>
  <span class="trust-sep">·</span>
  <div class="trust-item">👩 Mujeres al frente del proyecto</div>
  <span class="trust-sep">·</span>
  <div class="trust-item">✅ +200 clientas atendidas</div>
  <span class="trust-sep">·</span>
  <div class="trust-item">🎛️ 100% bajo tu control, siempre</div>
</div>

<!-- ==================== TE ENTENDEMOS ==================== -->
<section class="tis-section">
  <div class="tis-container">
    <div class="section-label reveal">Te entendemos</div>
    <h2 class="reveal">Sabemos bien cómo es el día a día.<br /><em>No lo asumimos. Lo escuchamos.</em></h2>
    <div class="problemas-grid reveal">
      {problemas.map((p) => (
        <div class="problema-card">
          <div class="problema-icon">{p.icon}</div>
          <h3>{p.titulo}</h3>
          <p>{p.descripcion}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ==================== SERVICIOS ==================== -->
<section class="tis-section tis-section--dark" id="servicios">
  <div class="tis-container">
    <div class="section-label reveal">Servicios</div>
    <h2 class="reveal">Lo que hacemos — y por qué importa.<br /><em>Siete servicios hechos para ti.</em></h2>

    <!-- ——— 01 Chatbot ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">01</div>
          <div>
            <h3>Chatbot 24/7 — Tu primer filtro inteligente</h3>
            <p class="servicio-desc">Un asistente que responde, filtra y agenda por ti. A las 3 AM, un domingo o mientras estás atendiendo.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>Responde preguntas frecuentes automáticamente (tarifas, zonas, disponibilidad)</li>
          <li>Filtra clientes según tus criterios — tú defines quién pasa</li>
          <li>Agenda citas directo al calendario sin que tú toques el teléfono</li>
          <li>Número dedicado separado de tu WhatsApp personal</li>
          <li>Escala a ti solo cuando de verdad se necesita</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Valentina, Valparaíso — Pasé de 140 mensajes diarios a revisar máximo 20. En 3 semanas."</p>
          <span class="testimonio-meta">Caso piloto · enero 2026</span>
        </div>
        <a href={waChatbot} class="tis-btn-servicio" target="_blank" rel="noopener">Quiero mi chatbot →</a>
      </div>

      <!-- MOCKUP: conversación WhatsApp -->
      <div class="servicio-mockup">
        <div class="mock-phone">
          <div class="mock-wa">
            <div class="mock-wa-header">
              <div class="mock-wa-avatar">🤖</div>
              <div class="mock-wa-info">
                <span class="mock-wa-name">Bot TIS</span>
                <span class="mock-wa-status">● en línea</span>
              </div>
              <span class="mock-wa-lock">🔒</span>
            </div>
            <div class="mock-wa-body">
              <div class="mock-bubble mock-bubble--in">Hola, ¿cuánto cobras?</div>
              <div class="mock-bubble mock-bubble--out">¡Hola! 👋 Para orientarte, ¿en qué ciudad estás?</div>
              <div class="mock-bubble mock-bubble--in">Santiago</div>
              <div class="mock-bubble mock-bubble--out">Perfecto ✓ Precios desde $XX. ¿Agendo para esta semana? 📅</div>
              <div class="mock-bubble mock-bubble--in">Sí, el jueves</div>
              <div class="mock-bubble mock-bubble--out mock-bubble--typing">Reservado para el jueves ✅<br/><span class="mock-ts">Respuesta automática · 03:17 AM</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ——— 02 Identidad visual ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">02</div>
          <div>
            <h3>Identidad visual y marca personal</h3>
            <p class="servicio-desc">Un avatar, banners y posts que te representen — sin exponer lo que no quieres exponer, con la estética que tú eliges.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>Diseño de avatar personalizado (cara visible u oculta, tú decides)</li>
          <li>Banners para redes sociales, OnlyFans, Fansly y Privacy</li>
          <li>Pack de posts editables para publicar sin depender de nadie</li>
          <li>Identidad visual coherente que transmite profesionalismo</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Isidora, Santiago — 'Antes subía cualquier cosa. Ahora mi perfil tiene cohesión y la gente lo nota.'"</p>
          <span class="testimonio-meta">Caso piloto · febrero 2026</span>
        </div>
        <a href={waMarca} class="tis-btn-servicio" target="_blank" rel="noopener">Quiero mi marca personal →</a>
      </div>

      <!-- MOCKUP: perfil de marca -->
      <div class="servicio-mockup">
        <div class="mock-brand">
          <div class="mock-banner-bg"></div>
          <div class="mock-brand-body">
            <div class="mock-avatar-wrap">
              <div class="mock-avatar-ring">
                <div class="mock-avatar-inner">✦</div>
              </div>
            </div>
            <div class="mock-brand-name">@mi.nombre.oficial</div>
            <div class="mock-brand-bio">Independiente · Santiago 🇨🇱</div>
            <div class="mock-brand-stats">
              <span><strong>1.4k</strong> seguidores</span>
              <span><strong>98</strong> posts</span>
            </div>
            <div class="mock-posts-grid">
              <div class="mock-post mock-post--a"></div>
              <div class="mock-post mock-post--b"></div>
              <div class="mock-post mock-post--c"></div>
              <div class="mock-post mock-post--d"></div>
              <div class="mock-post mock-post--e"></div>
              <div class="mock-post mock-post--f"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ——— 03 Protección ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">03</div>
          <div>
            <h3>Protección de contenido y anti-piratería</h3>
            <p class="servicio-desc">Marca de agua inteligente, monitoreo activo de leaks y gestión de takedowns DMCA. Porque lo que creas te pertenece.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>Marca de agua personalizada en fotos y videos antes de publicar</li>
          <li>Monitoreo continuo en foros, Telegram, sitios de descarga y redes</li>
          <li>Gestión de takedowns DMCA (notificaciones legales de eliminación)</li>
          <li>Alertas en tiempo real si aparece contenido tuyo sin permiso</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Andrea, Concepción — 'Llevaba 2 años con fotos mías en un foro. En 10 días las bajaron.'"</p>
          <span class="testimonio-meta">Caso piloto · marzo 2026</span>
        </div>
        <a href={waProteccion} class="tis-btn-servicio" target="_blank" rel="noopener">Proteger mi contenido →</a>
      </div>

      <!-- MOCKUP: imagen con marca de agua + alerta -->
      <div class="servicio-mockup">
        <div class="mock-protect-wrap">
          <div class="mock-protect-img">
            <div class="mock-img-gradient"></div>
            <div class="mock-watermark-grid" aria-hidden="true">
              {Array.from({length: 9}).map(() => (
                <span class="mock-wm-text">© @mi.nombre · TIS</span>
              ))}
            </div>
            <div class="mock-protect-badge">🛡️ Contenido protegido</div>
          </div>
          <div class="mock-alert-strip mock-alert-strip--warn">
            <span class="mock-alert-dot"></span>
            Detección en Telegram — takedown enviado
          </div>
          <div class="mock-alert-strip mock-alert-strip--ok">
            <span class="mock-alert-dot mock-alert-dot--ok"></span>
            Contenido eliminado · hace 8 horas
          </div>
        </div>
      </div>
    </div>

    <!-- ——— 04 Capacitación ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">04</div>
          <div>
            <h3>Capacitación 1-a-1</h3>
            <p class="servicio-desc">Sesiones personalizadas para que entiendas las herramientas, las plataformas y cómo protegerte digitalmente — sin jerga técnica, a tu ritmo.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>Configuración y uso de redes sociales, OnlyFans, Fansly o Privacy</li>
          <li>Seguridad digital: qué compartir, qué nunca compartir, cómo separar identidades</li>
          <li>Cómo usar el chatbot, la agenda y las métricas sin necesitar a nadie</li>
          <li>Sesiones por videollamada, privadas, sin grabaciones</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Catalina, Viña del Mar — 'Nunca había entendido realmente cómo funcionaba el algoritmo de OF. Después de la sesión, todo cambió.'"</p>
          <span class="testimonio-meta">Caso piloto · abril 2026</span>
        </div>
        <a href={waCapacitacion} class="tis-btn-servicio" target="_blank" rel="noopener">Quiero una sesión →</a>
      </div>

      <!-- MOCKUP: videollamada -->
      <div class="servicio-mockup">
        <div class="mock-call">
          <div class="mock-call-screen">
            <div class="mock-call-main">
              <div class="mock-call-avatar mock-call-avatar--tutor">T</div>
              <div class="mock-call-label">Tutora TIS · compartiendo pantalla</div>
              <div class="mock-call-screenshare">
                <div class="mock-ss-bar"></div>
                <div class="mock-ss-bar mock-ss-bar--long"></div>
                <div class="mock-ss-bar mock-ss-bar--med"></div>
                <div class="mock-ss-bar"></div>
              </div>
            </div>
            <div class="mock-call-self">
              <div class="mock-call-avatar mock-call-avatar--self">Tú</div>
            </div>
          </div>
          <div class="mock-call-controls">
            <div class="mock-ctrl">🎤</div>
            <div class="mock-ctrl mock-ctrl--hang">✕</div>
            <div class="mock-ctrl">📷</div>
          </div>
          <div class="mock-call-badge">🔒 Sesión privada · sin grabación</div>
        </div>
      </div>
    </div>

    <!-- ——— 05 Setup plataformas ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">05</div>
          <div>
            <h3>Setup inicial OnlyFans / Fansly / Privacy</h3>
            <p class="servicio-desc">Configuramos tu cuenta, tus precios, tus mensajes automáticos y tu estrategia de contenido — para que empieces a generar ingresos sin pasos en falso.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>Apertura y configuración completa de la plataforma que elijas</li>
          <li>Definición de precios (suscripción, PPV, mensajes de pago)</li>
          <li>Mensajes de bienvenida y respuestas automáticas listas para usar</li>
          <li>Estrategia inicial de contenido y frecuencia de publicación</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Daniela, Santiago — 'Me demoré 4 meses en abrir mi OnlyFans por miedo a hacerlo mal. Con Budgt TIS lo tuve listo en una semana.'"</p>
          <span class="testimonio-meta">Caso piloto · diciembre 2025</span>
        </div>
        <a href={waSetupPlat} class="tis-btn-servicio" target="_blank" rel="noopener">Quiero mi setup →</a>
      </div>

      <!-- MOCKUP: perfil de plataforma -->
      <div class="servicio-mockup">
        <div class="mock-platform">
          <div class="mock-plat-cover"></div>
          <div class="mock-plat-body">
            <div class="mock-plat-avatar">M</div>
            <div class="mock-plat-name">@mi_perfil_oficial</div>
            <div class="mock-plat-stats">
              <div class="mock-plat-stat"><strong>284</strong><span>Fans</span></div>
              <div class="mock-plat-stat"><strong>$18</strong><span>/ mes</span></div>
              <div class="mock-plat-stat"><strong>52</strong><span>Posts</span></div>
            </div>
            <div class="mock-plat-checks">
              <div class="mock-check mock-check--done">✓ Precio de suscripción configurado</div>
              <div class="mock-check mock-check--done">✓ Mensaje de bienvenida automático</div>
              <div class="mock-check mock-check--done">✓ Estrategia de contenido lista</div>
              <div class="mock-check mock-check--done">✓ PPV configurado desde $X</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ——— 06 Reportería ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">06</div>
          <div>
            <h3>Reportería y análisis mensual</h3>
            <p class="servicio-desc">Un informe mensual claro, en español simple, con los números que importan — para que tomes decisiones con información, no con intuición.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>Métricas de tus redes y plataformas en un solo lugar</li>
          <li>Análisis de qué días, horarios y formatos te generan más ingresos</li>
          <li>Recomendaciones concretas para el mes siguiente</li>
          <li>Sin hojas de cálculo complicadas — directo al grano</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Karla, Temuco — 'El reporte me mostró que los martes eran mis mejores días y yo los tenía bloqueados. Cambié la agenda y subí un 20%.'"</p>
          <span class="testimonio-meta">Caso piloto · febrero 2026</span>
        </div>
        <a href={waReportes} class="tis-btn-servicio" target="_blank" rel="noopener">Quiero mis reportes →</a>
      </div>

      <!-- MOCKUP: dashboard con gráfico -->
      <div class="servicio-mockup">
        <div class="mock-dashboard">
          <div class="mock-dash-header">
            <div>
              <div class="mock-dash-title">Ingresos · Junio 2026</div>
              <div class="mock-dash-sub">vs. mes anterior</div>
            </div>
            <div class="mock-dash-kpi">+34% <span>↑</span></div>
          </div>
          <div class="mock-chart">
            <div class="mock-bar-wrap"><div class="mock-bar" style="height:45%"></div><span>L</span></div>
            <div class="mock-bar-wrap"><div class="mock-bar" style="height:68%"></div><span>M</span></div>
            <div class="mock-bar-wrap"><div class="mock-bar mock-bar--accent" style="height:100%"></div><span>X</span></div>
            <div class="mock-bar-wrap"><div class="mock-bar" style="height:52%"></div><span>J</span></div>
