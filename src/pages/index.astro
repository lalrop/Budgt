---
import BaseLayout from '../layouts/BaseLayout.astro';
import FAQItem from '../components/FAQItem.astro';
import { getWhatsAppUrl } from '../utils/constants';

const waGeneral      = getWhatsAppUrl('Hola, me interesa digitalizar mi negocio con Budgt Emprende.');
const waChatbot      = getWhatsAppUrl('Hola, me interesa el Chatbot WhatsApp 24/7 para mi negocio (Budgt Emprende).');
const waMarca        = getWhatsAppUrl('Hola, me interesa el servicio de identidad visual y marca para mi negocio (Budgt Emprende).');
const waGoogle       = getWhatsAppUrl('Hola, me interesa el servicio de Google Business y visibilidad local (Budgt Emprende).');
const waCapacitacion = getWhatsAppUrl('Hola, me interesa una sesión de capacitación digital 1-a-1 (Budgt Emprende).');
const waTienda       = getWhatsAppUrl('Hola, me interesa el Setup de tienda online para mi negocio (Budgt Emprende).');
const waReportes     = getWhatsAppUrl('Hola, me interesa el servicio de reportería y análisis mensual (Budgt Emprende).');
const waPagina       = getWhatsAppUrl('Hola, me interesa una página web profesional para mi negocio (Budgt Emprende).');
const waInicio       = getWhatsAppUrl('Hola, me interesa el Plan Inicio de Budgt Emprende.');
const waCrecimiento  = getWhatsAppUrl('Hola, me interesa el Plan Crecimiento de Budgt Emprende. Es el más vendido.');
const waSetupUnico   = getWhatsAppUrl('Hola, me interesa el Plan Setup Único de Budgt Emprende (pago único).');
const waAvanzado     = getWhatsAppUrl('Hola, me interesa el Plan Avanzado de Budgt Emprende.');
const waWeb          = getWhatsAppUrl('Hola, me interesa la página web profesional de Budgt Emprende.');

const problemas = [
  { icon: '📱', titulo: 'Usas tu WhatsApp personal para el negocio',  descripcion: 'Los mensajes de clientes se mezclan con los de tu familia. Pierdes pedidos, olvidas responder y no hay forma de separar lo personal de lo laboral.' },
  { icon: '🐌', titulo: 'Los clientes esperan y se van',             descripcion: 'No alcanzas a responder todos los mensajes a tiempo. Mientras tardas, el cliente ya le escribió a la competencia. Ventas perdidas que ni sabías que tenías.' },
  { icon: '🎨', titulo: 'Tu imagen no refleja lo bueno que eres',    descripcion: 'Logo hecho en Word, fotos con poca luz, colores distintos en cada red social. Tu producto es bueno — pero la imagen dice lo contrario.' },
  { icon: '🗺️', titulo: 'No te encuentran en Google',               descripcion: 'Cuando alguien busca lo que tú vendes cerca de su casa, no apareces. Esas búsquedas son clientes listos para comprar que van a otro lado.' },
  { icon: '📦', titulo: 'Vendes solo en persona o por mensaje',      descripcion: 'No tienes forma de vender o agendar en línea. Tus clientes tienen que llamar, esperar, volver. La competencia ya cobra por internet.' },
  { icon: '📊', titulo: 'No sabes si estás creciendo o estancado',   descripcion: 'Trabajas mucho pero no tienes claro si el mes fue mejor que el anterior, qué funciona en redes o de dónde vienen tus mejores clientes.' },
];

const faqs = [
  { question: '¿Tengo que saber de tecnología para contratar esto?',    answer: 'Para nada. Nos encargamos de todo lo técnico. Tú nos cuentas de tu negocio y nosotros hacemos el resto. Te explicamos todo en lenguaje simple, sin tecnicismos.' },
  { question: '¿Funciona para cualquier tipo de negocio?',              answer: 'Sí. Hemos trabajado con restoranes, peluquerías, talleres, tiendas de ropa, servicios a domicilio, profesionales independientes y muchos más. Si tienes clientes, te podemos ayudar.' },
  { question: '¿Puedo contratar solo un servicio?',                    answer: 'Absolutamente. No hay paquete obligatorio. Muchos emprendedores empiezan con el chatbot o la página web y van sumando a medida que crecen.' },
  { question: '¿Cuánto tarda en estar listo todo?',                    answer: 'El chatbot tarda entre 5 y 10 días hábiles. La página web entre 7 y 14 días. Los demás servicios se coordinan contigo según tu disponibilidad.' },
  { question: '¿Puedo cancelar cuando quiera?',                        answer: 'Sí. Los planes mensuales no tienen permanencia mínima. Cancelas avisándonos antes del siguiente ciclo de facturación. Sin letra chica.' },
  { question: '¿Trabajan fuera de Santiago?',                          answer: 'Sí, 100% remoto. Tenemos clientes en todo Chile. La coordinación es por WhatsApp y videollamada, sin importar dónde estés.' },
  { question: '¿Qué pasa si quiero cambiar de plan?',                  answer: 'Puedes subir o bajar de plan cuando quieras. Te acomodamos a lo que el negocio necesita en cada momento.' },
  { question: '¿Cómo se paga?',                                        answer: 'Por transferencia bancaria o WebPay. Los planes mensuales se cobran al inicio de cada ciclo. El setup único se paga antes de comenzar el trabajo.' },
];
---

<BaseLayout
  title="Budgt — Digitalización para negocios en Chile"
  description="Chatbot WhatsApp, página web, Google Business, tienda online y más. Tecnología accesible para emprendedores y pequeños negocios chilenos. Sin saber de tecnología."
  page="emprende"
  canonical="https://budgt.cl"
  navLinks={[
    { text: 'Servicios',   href: '#servicios'    },
    { text: 'Planes',      href: '#planes'        },
    { text: 'Testimonios', href: '#testimonios'   },
    { text: 'FAQ',         href: '#faq'           },
  ]}
  navCtaText="Quiero crecer →"
>

<!-- ==================== HERO ==================== -->
<section class="emp-hero">
  <div class="emp-hero-tag">Budgt · Para negocios reales · 🇨🇱 Chile</div>
  <h1>Tu negocio lleva años funcionando.<br /><em>Es hora de que trabaje solo.</em></h1>
  <p class="emp-hero-sub">
    Digitalizamos tu negocio paso a paso — chatbot de WhatsApp, página web, Google, tienda online
    y más. Sin tecnicismos, sin contratos raros, sin necesitar saber de tecnología.
  </p>
  <div class="emp-hero-actions">
    <a href={waGeneral} class="emp-btn-wa" target="_blank" rel="noopener">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.125.558 4.167 1.618 5.955L.057 23.928a.5.5 0 0 0 .611.611l5.973-1.561A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.96 9.96 0 0 1-5.073-1.384l-.363-.215-3.763.984.984-3.763-.215-.363A9.96 9.96 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
      Hablar por WhatsApp
    </a>
    <a href="#servicios" class="emp-btn-ghost">Ver servicios ↓</a>
  </div>
  <div class="emp-hero-badges">
    <span class="emp-badge">🇨🇱 Chile</span>
    <span class="emp-badge-sep">·</span>
    <span class="emp-badge">Sin tecnicismos</span>
    <span class="emp-badge-sep">·</span>
    <span class="emp-badge">Resultados reales</span>
    <span class="emp-badge-sep">·</span>
    <span class="emp-badge">24/7</span>
  </div>

  <!-- Hero animado: mini mockup flotante -->
  <div class="emp-hero-mockup" aria-hidden="true">
    <div class="hero-mock-phone">
      <div class="hero-mock-wa-header">
        <div class="hero-mock-avatar">🏪</div>
        <div><div class="hero-mock-name">Mi Negocio Bot</div><div class="hero-mock-online">● en línea</div></div>
      </div>
      <div class="hero-mock-body">
        <div class="hero-bubble hero-bubble--in">Hola, ¿están abiertos?</div>
        <div class="hero-bubble hero-bubble--out">¡Hola! 👋 Sí, atendemos Lu–V de 9 a 19 hrs. ¿En qué te ayudo?</div>
        <div class="hero-bubble hero-bubble--in">¿Cuánto cuesta el servicio X?</div>
        <div class="hero-bubble hero-bubble--out">El servicio X tiene un valor de $15.000. ¿Te agendo para esta semana? 📅</div>
      </div>
      <div class="hero-mock-typing">
        <span class="hero-dot"></span><span class="hero-dot"></span><span class="hero-dot"></span>
        <span class="hero-mock-ts">Respuesta automática · ahora</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll">
    <div class="scroll-line"></div>
    <span>Desplázate</span>
  </div>
</section>

<!-- ==================== TRUST BAR ==================== -->
<div class="emp-trust-bar">
  <div class="trust-item">🏆 +80 negocios digitalizados</div>
  <span class="trust-sep">·</span>
  <div class="trust-item">⚡ Resultados desde la semana 1</div>
  <span class="trust-sep">·</span>
  <div class="trust-item">🇨🇱 100% remoto · todo Chile</div>
  <span class="trust-sep">·</span>
  <div class="trust-item">🔒 Sin contratos largos ni letra chica</div>
</div>

<!-- ==================== PROBLEMAS ==================== -->
<section class="emp-section">
  <div class="emp-container">
    <div class="section-label reveal">Te reconocemos</div>
    <h2 class="reveal">
      Si tienes un buen negocio pero sientes que<br />
      <em>la tecnología te quedó grande — esto es para ti.</em>
    </h2>
    <div class="emp-problemas-grid reveal">
      {problemas.map((p) => (
        <div class="emp-problema-card">
          <div class="emp-problema-icon">{p.icon}</div>
          <h3>{p.titulo}</h3>
          <p>{p.descripcion}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ==================== SERVICIOS ==================== -->
<section class="emp-section emp-section--dark" id="servicios">
  <div class="emp-container">
    <div class="section-label reveal">Servicios</div>
    <h2 class="reveal">
      Lo que hacemos por tu negocio.<br />
      <em>Siete herramientas. Un solo equipo.</em>
    </h2>

    <!-- ——— 01 Chatbot WhatsApp ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">01</div>
          <div>
            <h3>Chatbot WhatsApp 24/7</h3>
            <p class="servicio-desc">Tu primer empleado digital: atiende consultas, filtra clientes y agenda citas aunque estés durmiendo o trabajando.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>Responde automáticamente: horarios, precios, ubicación y más</li>
          <li>Agenda citas o pedidos directo al calendario sin intervención tuya</li>
          <li>Número de WhatsApp Business separado del personal</li>
          <li>Te avisa solo cuando el cliente de verdad necesita hablar contigo</li>
          <li>Se configura con el vocabulario y tono de tu negocio</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Roberto, Peluquería Santiago — 'Antes perdía 3 o 4 horas al día respondiendo mensajes. Ahora el bot agenda todo y yo me concentro en cortar pelo.'"</p>
          <span class="testimonio-meta">Cliente desde octubre 2025</span>
        </div>
        <a href={waChatbot} class="emp-btn-servicio" target="_blank" rel="noopener">Quiero mi chatbot →</a>
      </div>

      <!-- MOCKUP animado: chat WhatsApp -->
      <div class="servicio-mockup">
        <div class="mock-phone">
          <div class="mock-wa-header">
            <div class="mock-wa-avatar">🏪</div>
            <div class="mock-wa-info">
              <span class="mock-wa-name">Mi Negocio Bot</span>
              <span class="mock-wa-status">● en línea siempre</span>
            </div>
          </div>
          <div class="mock-wa-body">
            <div class="mock-bubble mock-bubble--in b1">¿Cuánto cobran por X?</div>
            <div class="mock-bubble mock-bubble--out b2">¡Hola! 👋 El servicio X vale $15.000. ¿Agendo para esta semana?</div>
            <div class="mock-bubble mock-bubble--in b3">Sí, el miércoles</div>
            <div class="mock-bubble mock-bubble--out b4">✅ Reservado miércoles 10 AM. Te confirmo por acá. <br/><span class="mock-ts">Respuesta automática · 11:47 PM</span></div>
          </div>
          <div class="mock-typing-indicator">
            <span class="tdot"></span><span class="tdot"></span><span class="tdot"></span>
          </div>
        </div>
      </div>
    </div>

    <!-- ——— 02 Identidad visual ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">02</div>
          <div>
            <h3>Identidad visual y marca profesional</h3>
            <p class="servicio-desc">Una imagen que genera confianza al instante — desde el logo hasta las plantillas de posts que usas todos los días.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>Logo y paleta de colores profesional para tu rubro</li>
          <li>Banners para WhatsApp Business, Instagram y Facebook</li>
          <li>Tarjeta de presentación digital (compartible por WhatsApp)</li>
          <li>Pack de plantillas de posts editables para publicar solo</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Patricia, Pastelería Viña del Mar — 'Con el logo nuevo y las plantillas, mis publicaciones parecen de una marca grande. Mis clientas me lo dicen.'"</p>
          <span class="testimonio-meta">Clienta desde noviembre 2025</span>
        </div>
        <a href={waMarca} class="emp-btn-servicio" target="_blank" rel="noopener">Quiero mi marca →</a>
      </div>

      <!-- MOCKUP animado: identidad de marca -->
      <div class="servicio-mockup">
        <div class="mock-brand">
          <div class="mock-brand-banner"></div>
          <div class="mock-brand-body">
            <div class="mock-brand-logo-wrap">
              <div class="mock-brand-logo">
                <span class="mock-logo-icon">✦</span>
                <span class="mock-logo-text">Mi Negocio</span>
              </div>
            </div>
            <div class="mock-brand-palette">
              <div class="mock-swatch mock-swatch--1" title="Color primario"></div>
              <div class="mock-swatch mock-swatch--2" title="Color secundario"></div>
              <div class="mock-swatch mock-swatch--3" title="Acento"></div>
              <div class="mock-swatch mock-swatch--4" title="Neutro"></div>
            </div>
            <div class="mock-brand-assets">
              <div class="mock-asset mock-asset--banner">
                <div class="mock-asset-label">Banner IG</div>
                <div class="mock-asset-preview"></div>
              </div>
              <div class="mock-asset mock-asset--card">
                <div class="mock-asset-label">Tarjeta digital</div>
                <div class="mock-asset-card-body">
                  <div class="mock-card-logo">✦</div>
                  <div class="mock-card-lines">
                    <div class="mock-card-line mock-card-line--name"></div>
                    <div class="mock-card-line mock-card-line--job"></div>
                    <div class="mock-card-line mock-card-line--phone"></div>
                  </div>
                </div>
              </div>
              <div class="mock-asset mock-asset--post">
                <div class="mock-asset-label">Post IG</div>
                <div class="mock-asset-post-body">
                  <div class="mock-post-img"></div>
                  <div class="mock-post-bar"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ——— 03 Google Business ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">03</div>
          <div>
            <h3>Google Business y visibilidad local</h3>
            <p class="servicio-desc">Que tus clientes te encuentren en Google Maps cuando buscan lo que tú vendes cerca de su casa. Con reseñas, horarios y fotos que convencen.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>Configuración completa de Google Business Profile</li>
          <li>Apareces en Google Maps y búsquedas "cerca de mí"</li>
          <li>Fotos, descripción y categorías optimizadas para tu rubro</li>
          <li>Respuestas automáticas a reseñas de clientes</li>
          <li>Seguimiento de cuántas personas te encontraron en Google</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Jorge, Ferretería Temuco — 'En 3 semanas de tener el perfil configurado, empezaron a llamar clientes que nos encontraron buscando en Google.'"</p>
          <span class="testimonio-meta">Cliente desde diciembre 2025</span>
        </div>
        <a href={waGoogle} class="emp-btn-servicio" target="_blank" rel="noopener">Quiero aparecer en Google →</a>
      </div>

      <!-- MOCKUP animado: resultado de búsqueda Google -->
      <div class="servicio-mockup">
        <div class="mock-google">
          <div class="mock-google-bar">
            <span class="mock-g-icon">🔍</span>
            <span class="mock-g-query">ferretería cerca de mí</span>
          </div>
          <div class="mock-google-result">
            <div class="mock-result-map"></div>
            <div class="mock-result-card">
              <div class="mock-result-name">Mi Ferretería</div>
              <div class="mock-result-stars">
                <span class="mock-star s1">★</span>
                <span class="mock-star s2">★</span>
                <span class="mock-star s3">★</span>
                <span class="mock-star s4">★</span>
                <span class="mock-star s5">★</span>
                <span class="mock-result-rating">4.8 (127 reseñas)</span>
              </div>
              <div class="mock-result-meta">Ferretería · Abierto ahora</div>
              <div class="mock-result-addr">📍 Calle Ejemplo 123, Temuco</div>
              <div class="mock-result-actions">
                <div class="mock-result-btn">Cómo llegar</div>
                <div class="mock-result-btn">Llamar</div>
                <div class="mock-result-btn">Sitio web</div>
              </div>
            </div>
          </div>
          <div class="mock-google-reviews">
            <div class="mock-review r1">
              <span class="mock-review-stars">★★★★★</span>
              <span class="mock-review-text">"Excelente atención, muy completos."</span>
            </div>
            <div class="mock-review r2">
              <span class="mock-review-stars">★★★★★</span>
              <span class="mock-review-text">"Los mejores precios de la zona."</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ——— 04 Capacitación ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">04</div>
          <div>
            <h3>Capacitación digital 1-a-1</h3>
            <p class="servicio-desc">Sesiones personalizadas para que entiendas las herramientas que usas — sin jerga técnica, a tu ritmo, con ejemplos de tu negocio.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>WhatsApp Business, Google, Instagram y Facebook para negocios</li>
          <li>Cómo usar el chatbot, el calendario y los reportes sin ayuda</li>
          <li>Seguridad digital: protege tus cuentas y contraseñas</li>
          <li>Sesiones por videollamada, privadas, con material de repaso</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Ana, Servicio de Catering Concepción — 'Aprendí a manejar todo en un par de sesiones. Ahora publico sola y entiendo lo que miran mis clientes.'"</p>
          <span class="testimonio-meta">Clienta desde enero 2026</span>
        </div>
        <a href={waCapacitacion} class="emp-btn-servicio" target="_blank" rel="noopener">Quiero una sesión →</a>
      </div>

      <!-- MOCKUP animado: videollamada con pantalla compartida -->
      <div class="servicio-mockup">
        <div class="mock-call">
          <div class="mock-call-screen">
            <div class="mock-call-main-area">
              <div class="mock-tutor">
                <div class="mock-tutor-avatar">T</div>
                <div class="mock-tutor-label">Tutor Budgt · compartiendo pantalla</div>
                <div class="mock-screenshare">
                  <div class="mock-ss-window">
                    <div class="mock-ss-topbar">
                      <span class="mock-ss-dot r"></span>
                      <span class="mock-ss-dot y"></span>
                      <span class="mock-ss-dot g"></span>
                    </div>
                    <div class="mock-ss-content">
                      <div class="mock-ss-line mock-ss-line--title"></div>
                      <div class="mock-ss-line"></div>
                      <div class="mock-ss-line mock-ss-line--short"></div>
                    </div>
                  </div>
                </div>
              </div>
              <div class="mock-self-cam">
                <div class="mock-self-avatar">Tú</div>
              </div>
            </div>
          </div>
          <div class="mock-call-controls">
            <div class="mock-ctrl">🎤</div>
            <div class="mock-ctrl mock-ctrl--hang">✕</div>
            <div class="mock-ctrl">📷</div>
            <div class="mock-ctrl">💬</div>
          </div>
          <div class="mock-call-footer">🔒 Sesión privada · sin grabación · material enviado por WhatsApp</div>
        </div>
      </div>
    </div>

    <!-- ——— 05 Tienda online ——— -->
    <div class="servicio-block reveal">
      <div class="servicio-content">
        <div class="servicio-header">
          <div class="servicio-num">05</div>
          <div>
            <h3>Tienda online y venta digital</h3>
            <p class="servicio-desc">Vende y agenda en línea aunque no sepas nada de tecnología. Catálogo, carrito de compras, pagos en línea — todo funcionando desde el día uno.</p>
          </div>
        </div>
        <ul class="servicio-bullets">
          <li>Catálogo de productos o servicios con fotos y precios</li>
          <li>Sistema de pedidos o reservas en línea</li>
          <li>Integración con WebPay, Mercado Pago y transferencia</li>
          <li>Órdenes de compra automáticas por WhatsApp cuando alguien compra</li>
          <li>Sin comisiones extras — la plataforma es tuya</li>
        </ul>
        <div class="servicio-testimonio">
          <p>"Claudia, Tienda de Ropa Valparaíso — 'Empecé a recibir pedidos de personas que nunca habían pisado mi local. El primer mes ya pagué el servicio.'"</p>
          <span class="testimonio-meta">Clienta desde febrero 2026</span>
        </div>
        <a href={waTienda} class="emp-btn-servicio" target="_blank" rel="noopener">Quiero mi tienda →</a>
      </div>

      <!-- MOCKUP animado: tienda online con carrito -->
      <div class="servicio-mockup">
        <div class="mock-store">
          <div class="mock-store-header">
            <span class="mock-store-logo">🏪 Mi Tienda</span>
            <div class="mock-cart-icon">🛒 <span class="mock-cart-badge">2</span></div>
          </div>
          <div class="mock-products">
            <div class="mock-product p1">
              <div class="mock-product-img"></div>
