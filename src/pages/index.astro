<style>
/* =====================================================
   VARIABLES — ámbar cálido para emprendedores
   ===================================================== */
:root {
  --emp-accent:     #e07b3a;
  --emp-accent-lt:  #f0a870;
  --emp-accent-dim: rgba(224, 123, 58, 0.12);
  --emp-accent-faint: rgba(224, 123, 58, 0.06);
}

/* =====================================================
   HERO
   ===================================================== */
.emp-hero {
  min-height: 100vh;
  display: grid;
  grid-template-columns: 1fr auto;
  grid-template-rows: auto auto auto auto auto;
  align-content: center;
  gap: 0;
  padding: 7rem 2.5rem 4rem;
  position: relative;
  overflow: hidden;
}

.emp-hero::before {
  content: '';
  position: absolute;
  top: -20%;
  left: -10%;
  width: 55vw;
  height: 55vw;
  border-radius: 50%;
  background: radial-gradient(circle, var(--emp-accent-dim) 0%, transparent 70%);
  pointer-events: none;
}

.emp-hero-tag {
  grid-column: 1;
  display: inline-block;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--emp-accent);
  border: 1px solid rgba(224,123,58,0.35);
  padding: 0.35rem 0.9rem;
  margin-bottom: 2.2rem;
  width: fit-content;
}

.emp-hero h1 {
  grid-column: 1;
  font-family: var(--font-serif);
  font-size: clamp(2.8rem, 6vw, 5rem);
  line-height: 1.05;
  letter-spacing: -0.03em;
  max-width: 820px;
  margin-bottom: 1.8rem;
}

.emp-hero h1 em { font-style: italic; color: var(--gray-400); }

.emp-hero-sub {
  grid-column: 1;
  font-size: clamp(1rem, 1.8vw, 1.15rem);
  color: var(--gray-400);
  max-width: 560px;
  line-height: 1.72;
  margin-bottom: 2.5rem;
  font-weight: 300;
}

.emp-hero-actions {
  grid-column: 1;
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-bottom: 3rem;
}

.emp-hero-badges {
  grid-column: 1;
  display: flex;
  align-items: center;
  gap: 0.75rem;
  flex-wrap: wrap;
}

.emp-badge     { font-size: 0.78rem; color: var(--gray-500); }
.emp-badge-sep { color: var(--gray-700); }

/* Hero mockup flotante */
.emp-hero-mockup {
  grid-column: 2;
  grid-row: 1 / 6;
  display: flex;
  align-items: center;
  justify-content: center;
  padding-left: 4rem;
  padding-top: 3rem;
}

.hero-mock-phone {
  width: 260px;
  background: #0d0d1a;
  border: 1px solid rgba(224,123,58,0.25);
  border-radius: 2px;
  overflow: hidden;
  box-shadow: 0 0 60px var(--emp-accent-dim), 0 20px 60px rgba(0,0,0,0.4);
  animation: heroFloat 4s ease-in-out infinite;
}

@keyframes heroFloat {
  0%, 100% { transform: translateY(0px); }
  50%       { transform: translateY(-12px); }
}

.hero-mock-wa-header {
  background: #1a1a2e;
  padding: 0.7rem 0.9rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.hero-mock-avatar {
  width: 30px; height: 30px;
  border-radius: 50%;
  background: var(--emp-accent-dim);
  border: 1px solid var(--emp-accent);
  display: flex; align-items: center; justify-content: center;
  font-size: 0.9rem;
}
.hero-mock-name   { font-size: 0.75rem; font-weight: 600; color: var(--white); }
.hero-mock-online { font-size: 0.62rem; color: #4ade80; }

.hero-mock-body {
  padding: 0.8rem;
  display: flex;
  flex-direction: column;
  gap: 0.45rem;
  background: #080814;
}

.hero-bubble {
  padding: 0.45rem 0.7rem;
  border-radius: 3px;
  font-size: 0.72rem;
  line-height: 1.4;
  opacity: 0;
}
.hero-bubble--in  { background: var(--gray-800); color: var(--gray-300); align-self: flex-start; animation: heroBubble 0.4s ease forwards; }
.hero-bubble--out { background: rgba(224,123,58,0.18); border: 1px solid rgba(224,123,58,0.25); color: var(--gray-200); align-self: flex-end; animation: heroBubble 0.4s ease forwards; }

.hero-bubble:nth-child(1) { animation-delay: 0.8s; }
.hero-bubble:nth-child(2) { animation-delay: 1.6s; }
.hero-bubble:nth-child(3) { animation-delay: 2.8s; }
.hero-bubble:nth-child(4) { animation-delay: 3.6s; }

@keyframes heroBubble {
  from { opacity: 0; transform: translateY(6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.hero-mock-typing {
  padding: 0.5rem 0.8rem 0.7rem;
  background: #080814;
  display: flex;
  align-items: center;
  gap: 0.6rem;
}
.hero-dot {
  width: 5px; height: 5px;
  border-radius: 50%;
  background: var(--emp-accent);
  animation: dotPulse 1.4s ease-in-out infinite;
}
.hero-dot:nth-child(2) { animation-delay: 0.2s; }
.hero-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes dotPulse {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50%       { opacity: 1;   transform: scale(1.1); }
}
.hero-mock-ts { font-size: 0.58rem; color: var(--emp-accent); opacity: 0.7; }

.hero-scroll {
  position: absolute;
  bottom: 2rem;
  left: 2.5rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  color: var(--gray-600);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.scroll-line {
  width: 40px; height: 1px;
  background: var(--gray-600);
  animation: scrollLine 2s ease-in-out infinite;
}
@keyframes scrollLine {
  0%, 100% { transform: scaleX(1); opacity: 1; }
  50%       { transform: scaleX(0.4); opacity: 0.4; }
}

/* =====================================================
   BOTONES
   ===================================================== */
.emp-btn-wa {
  display: inline-flex;
  align-items: center;
  gap: 0.7rem;
  background: var(--wa-green);
  color: var(--white);
  font-family: var(--font-sans);
  font-weight: 600;
  font-size: 0.95rem;
  padding: 0.9rem 2rem;
  text-decoration: none;
  transition: opacity 0.2s;
}
.emp-btn-wa:hover { opacity: 0.88; }
.emp-btn-wa--large { font-size: 1.05rem; padding: 1.1rem 2.6rem; margin-bottom: 1.2rem; }

.emp-btn-ghost {
  color: var(--gray-400);
  font-size: 0.9rem;
  text-decoration: none;
  transition: color 0.2s;
}
.emp-btn-ghost:hover { color: var(--white); }

.emp-btn-servicio {
  display: inline-block;
  padding: 0.75rem 1.8rem;
  border: 1px solid var(--gray-700);
  color: var(--white);
  font-size: 0.88rem;
  font-weight: 500;
  text-decoration: none;
  transition: border-color 0.2s, color 0.2s;
  margin-top: 1.2rem;
}
.emp-btn-servicio:hover { border-color: var(--emp-accent); color: var(--emp-accent); }

/* =====================================================
   TRUST BAR
   ===================================================== */
.emp-trust-bar {
  background: var(--gray-900);
  border-top: 1px solid var(--gray-800);
  border-bottom: 1px solid var(--gray-800);
  padding: 1rem 2.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2rem;
  flex-wrap: wrap;
}
.trust-item { font-size: 0.82rem; color: var(--gray-400); }
.trust-sep  { color: var(--gray-700); }

/* =====================================================
   SECCIONES
   ===================================================== */
.emp-section { padding: 7rem 2.5rem; }
.emp-section--dark {
  background: var(--gray-900);
  border-top: 1px solid var(--gray-800);
  border-bottom: 1px solid var(--gray-800);
}
.emp-container         { max-width: 1100px; margin: 0 auto; }
.emp-container--narrow { max-width: 760px; }

.emp-section h2 {
  font-family: var(--font-serif);
  font-size: clamp(1.9rem, 3.5vw, 3rem);
  line-height: 1.1;
  letter-spacing: -0.02em;
  margin-bottom: 3.5rem;
}
.emp-section h2 em { font-style: italic; color: var(--gray-500); }

/* =====================================================
   PROBLEMAS
   ===================================================== */
.emp-problemas-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1px;
  background: var(--gray-800);
}
.emp-problema-card {
  background: var(--black);
  padding: 2rem 1.8rem;
  border-top: 2px solid transparent;
  transition: background 0.2s, border-color 0.2s;
}
.emp-problema-card:hover { background: var(--gray-900); border-top-color: var(--emp-accent); }
.emp-problema-icon { font-size: 1.4rem; margin-bottom: 1rem; }
.emp-problema-card h3 {
  font-family: var(--font-sans);
  font-size: 0.95rem; font-weight: 600; letter-spacing: 0;
  line-height: 1.3; margin-bottom: 0.8rem; color: var(--white);
}
.emp-problema-card p { font-size: 0.85rem; color: var(--gray-500); line-height: 1.75; font-weight: 300; }

/* =====================================================
   SERVICIOS
   ===================================================== */
.servicio-block {
  border-top: 1px solid var(--gray-800);
  padding: 4rem 0;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4rem;
  align-items: center;
}
.servicio-block:last-child { border-bottom: 1px solid var(--gray-800); }
.servicio-content { display: flex; flex-direction: column; }
.servicio-header  { display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 1.5rem; }
.servicio-num {
  font-family: var(--font-serif);
  font-size: 1.8rem; color: var(--emp-accent); opacity: 0.4;
  flex-shrink: 0; line-height: 1; margin-top: 0.2rem; min-width: 2.2rem;
}
.servicio-header h3 {
  font-family: var(--font-sans);
  font-size: 1.1rem; font-weight: 600; letter-spacing: 0;
  line-height: 1.3; margin-bottom: 0.5rem; color: var(--white);
}
.servicio-desc { font-size: 0.9rem; color: var(--gray-400); line-height: 1.7; font-weight: 300; }
.servicio-bullets { display: flex; flex-direction: column; gap: 0.6rem; margin-bottom: 1.5rem; }
.servicio-bullets li {
  font-size: 0.88rem; color: var(--gray-400); line-height: 1.55; font-weight: 300;
  padding-left: 1.3rem; position: relative;
}
.servicio-bullets li::before { content: '→'; position: absolute; left: 0; color: var(--emp-accent); font-size: 0.8rem; }
.servicio-testimonio { border-left: 2px solid var(--emp-accent); padding-left: 1rem; }
.servicio-testimonio p { font-size: 0.85rem; color: var(--gray-400); font-style: italic; line-height: 1.65; margin-bottom: 0.3rem; }
.testimonio-meta { font-size: 0.75rem; color: var(--gray-600); font-style: normal; }

.servicio-mockup { display: flex; align-items: center; justify-content: center; }

/* =====================================================
   MOCKUP 01 — Chat WhatsApp (animado)
   ===================================================== */
.mock-phone {
  width: 100%; max-width: 300px;
  border: 1px solid var(--gray-800);
  background: #0d0d1a;
  box-shadow: 0 0 40px var(--emp-accent-dim);
}
.mock-wa-header {
  background: #1a1a2e; padding: 0.7rem 0.9rem;
  display: flex; align-items: center; gap: 0.6rem;
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.mock-wa-avatar {
  width: 32px; height: 32px; border-radius: 50%;
  background: var(--emp-accent-dim); border: 1px solid var(--emp-accent);
  display: flex; align-items: center; justify-content: center; font-size: 0.95rem;
}
.mock-wa-info { flex: 1; }
.mock-wa-name   { font-size: 0.78rem; font-weight: 600; color: var(--white); }
.mock-wa-status { font-size: 0.62rem; color: #4ade80; }
.mock-wa-body {
  padding: 0.8rem; display: flex; flex-direction: column;
  gap: 0.5rem; background: #080814; min-height: 200px;
}
.mock-bubble {
  padding: 0.5rem 0.75rem; border-radius: 3px;
  font-size: 0.75rem; line-height: 1.4; max-width: 88%;
  opacity: 0;
}
.mock-bubble--in  { background: var(--gray-800); color: var(--gray-300); align-self: flex-start; }
.mock-bubble--out { background: rgba(224,123,58,0.18); border: 1px solid rgba(224,123,58,0.25); color: var(--gray-200); align-self: flex-end; }
.mock-ts { display: block; font-size: 0.6rem; color: var(--emp-accent); margin-top: 0.25rem; opacity: 0.8; }

/* Animaciones de burbujas al hacer scroll */
.reveal.visible .b1 { animation: bubbleIn 0.35s ease 0.1s forwards; }
.reveal.visible .b2 { animation: bubbleIn 0.35s ease 0.55s forwards; }
.reveal.visible .b3 { animation: bubbleIn 0.35s ease 1.1s forwards; }
.reveal.visible .b4 { animation: bubbleIn 0.35s ease 1.55s forwards; }

@keyframes bubbleIn {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

.mock-typing-indicator {
  padding: 0.5rem 0.8rem 0.6rem; background: #080814;
  display: flex; align-items: center; gap: 0.4rem;
}
.tdot {
  width: 5px; height: 5px; border-radius: 50%;
  background: var(--emp-accent);
  animation: dotPulse 1.4s ease-in-out infinite;
}
.tdot:nth-child(2) { animation-delay: 0.2s; }
.tdot:nth-child(3) { animation-delay: 0.4s; }

/* =====================================================
   MOCKUP 02 — Identidad visual (animado)
   ===================================================== */
.mock-brand {
  width: 100%; max-width: 320px;
  border: 1px solid var(--gray-800);
  background: #0d0d0d;
  box-shadow: 0 0 40px var(--emp-accent-dim);
  overflow: hidden;
}
.mock-brand-banner {
  height: 70px;
  background: linear-gradient(135deg, #1a0f00 0%, #2a1800 50%, #1a1000 100%);
  position: relative;
}
.mock-brand-banner::after {
  content: '';
  position: absolute; inset: 0;
  background: repeating-linear-gradient(45deg, rgba(224,123,58,0.08) 0px, rgba(224,123,58,0.08) 1px, transparent 1px, transparent 14px);
}
.mock-brand-body { padding: 0 1rem 1rem; }
.mock-brand-logo-wrap { margin-top: 0.8rem; margin-bottom: 0.7rem; }
.mock-brand-logo {
  display: inline-flex; align-items: center; gap: 0.5rem;
  opacity: 0;
}
.reveal.visible .mock-brand-logo { animation: fadeSlideUp 0.5s ease 0.2s forwards; }
.mock-logo-icon { font-size: 1.2rem; color: var(--emp-accent); }
.mock-logo-text { font-family: var(--font-serif); font-size: 1rem; color: var(--white); letter-spacing: 0.02em; }

.mock-brand-palette {
  display: flex; gap: 5px; margin-bottom: 0.8rem;
  opacity: 0;
}
.reveal.visible .mock-brand-palette { animation: fadeSlideUp 0.5s ease 0.5s forwards; }
.mock-swatch { width: 28px; height: 28px; border-radius: 50%; }
.mock-swatch--1 { background: var(--emp-accent); }
.mock-swatch--2 { background: #f0a870; }
.mock-swatch--3 { background: #1a1a2e; }
.mock-swatch--4 { background: var(--gray-600); }

.mock-brand-assets {
  display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px;
  opacity: 0;
}
.reveal.visible .mock-brand-assets { animation: fadeSlideUp 0.5s ease 0.8s forwards; }
.mock-asset { display: flex; flex-direction: column; gap: 4px; }
.mock-asset-label { font-size: 0.55rem; color: var(--gray-600); text-align: center; }
.mock-asset-preview { height: 36px; background: linear-gradient(135deg, #1a0f00, #2a1500); border: 1px solid var(--gray-800); border-radius: 1px; }
.mock-asset-card-body {
  height: 36px; background: var(--gray-900); border: 1px solid var(--gray-800);
  display: flex; align-items: center; gap: 4px; padding: 0 5px;
}
.mock-card-logo { font-size: 0.8rem; color: var(--emp-accent); }
.mock-card-lines { display: flex; flex-direction: column; gap: 3px; flex: 1; }
.mock-card-line { height: 3px; background: var(--gray-700); border-radius: 1px; }
.mock-card-line--name { width: 80%; }
.mock-card-line--job  { width: 60%; }
.mock-card-line--phone{ width: 70%; }
.mock-asset-post-body {
  height: 36px; background: var(--gray-900); border: 1px solid var(--gray-800);
  display: flex; flex-direction: column;
}
.mock-post-img { flex: 1; background: linear-gradient(135deg, #1a0f00, #2a1500); }
.mock-post-bar { height: 7px; background: var(--gray-800); }

@keyframes fadeSlideUp {
  from { opacity: 0; transform: translateY(8px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* =====================================================
   MOCKUP 03 — Google Business (animado)
   ===================================================== */
.mock-google {
  width: 100%; max-width: 320px;
  background: #0d0d0d;
  border: 1px solid var(--gray-800);
  box-shadow: 0 0 40px var(--emp-accent-dim);
  overflow: hidden;
}
.mock-google-bar {
  background: #111; padding: 0.6rem 0.8rem;
  display: flex; align-items: center; gap: 0.5rem;
  border-bottom: 1px solid var(--gray-800);
  font-size: 0.75rem; color: var(--gray-400);
}
.mock-g-icon { font-size: 0.85rem; }
.mock-g-query { color: var(--white); font-weight: 500; }
.mock-google-result { display: flex; gap: 0; }
.mock-result-map {
  width: 80px; min-height: 120px; flex-shrink: 0;
  background: linear-gradient(135deg, #111820 0%, #0a1015 100%);
  border-right: 1px solid var(--gray-800);
  position: relative;
}
.mock-result-map::after {
  content: '📍';
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  font-size: 1.2rem;
  animation: pinBounce 2s ease-in-out infinite;
}
@keyframes pinBounce {
  0%, 100% { transform: translate(-50%, -50%); }
  50%       { transform: translate(-50%, -60%); }
}
.mock-result-card { flex: 1; padding: 0.7rem 0.8rem; }
.mock-result-name { font-size: 0.82rem; font-weight: 700; color: var(--white); margin-bottom: 0.3rem; }
.mock-result-stars { display: flex; align-items: center; gap: 0.2rem; margin-bottom: 0.2rem; }
.mock-star { font-size: 0.7rem; color: var(--gray-700); }
.mock-result-rating { font-size: 0.65rem; color: var(--gray-500); margin-left: 0.2rem; }
/* Stars animation */
.reveal.visible .mock-star.s1 { animation: starFill 0.2s ease 0.3s forwards; }
.reveal.visible .mock-star.s2 { animation: starFill 0.2s ease 0.5s forwards; }
.reveal.visible .mock-star.s3 { animation: starFill 0.2s ease 0.7s forwards; }
.reveal.visible .mock-star.s4 { animation: starFill 0.2s ease 0.9s forwards; }
.reveal.visible .mock-star.s5 { animation: starFill 0.2s ease 1.1s forwards; }
@keyframes starFill {
  from { color: var(--gray-700); transform: scale(0.8); }
  to   { color: #f59e0b; transform: scale(1.2); }
}
.mock-result-meta { font-size: 0.65rem; color: var(--gray-500); margin-bottom: 0.2rem; }
.mock-result-addr { font-size: 0.65rem; color: var(--gray-500); margin-bottom: 0.5rem; }
.mock-result-actions { display: flex; gap: 4px; flex-wrap: wrap; }
.mock-result-btn {
  font-size: 0.6rem; padding: 0.25rem 0.5rem;
  border: 1px solid rgba(224,123,58,0.3);
  color: var(--emp-accent-lt); border-radius: 1px;
}
.mock-google-reviews {
  border-top: 1px solid var(--gray-800);
  padding: 0.5rem 0.8rem;
  display: flex; flex-direction: column; gap: 0.4rem;
}
.mock-review { display: flex; gap: 0.5rem; align-items: flex-start; opacity: 0; }
.reveal.visible .mock-review.r1 { animation: fadeSlideUp 0.4s ease 1.3s forwards; }
.reveal.visible .mock-review.r2 { animation: fadeSlideUp 0.4s ease 1.7s forwards; }
.mock-review-stars { font-size: 0.6rem; color: #f59e0b; flex-shrink: 0; }
.mock-review-text  { font-size: 0.65rem; color: var(--gray-500); font-style: italic; line-height: 1.3; }

/* =====================================================
   MOCKUP 04 — Videollamada (animado)
   ===================================================== */
.mock-call {
  width: 100%; max-width: 320px;
  background: #0d0d1a;
  border: 1px solid var(--gray-800);
  box-shadow: 0 0 40px var(--emp-accent-dim);
}
.mock-call-screen { height: 190px; background: #080814; position: relative; display: flex; align-items: center; justify-content: center; }
.mock-tutor { display: flex; flex-direction: column; align-items: center; gap: 0.4rem; }
.mock-tutor-avatar {
  width: 48px; height: 48px; border-radius: 50%;
  background: var(--emp-accent-dim); border: 2px solid var(--emp-accent);
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 1rem; color: var(--emp-accent-lt);
}
.mock-tutor-label { font-size: 0.65rem; color: var(--gray-500); }
.mock-screenshare {
  margin-top: 0.5rem;
  width: 100px;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--gray-800);
  border-radius: 2px;
  overflow: hidden;
}
.mock-ss-window {}
.mock-ss-topbar {
  background: var(--gray-800); padding: 3px 5px;
  display: flex; gap: 3px; align-items: center;
}
.mock-ss-dot { width: 5px; height: 5px; border-radius: 50%; }
.mock-ss-dot.r { background: #ef4444; }
.mock-ss-dot.y { background: #f59e0b; }
.mock-ss-dot.g { background: #22c55e; }
.mock-ss-content { padding: 5px 6px; display: flex; flex-direction: column; gap: 3px; }
.mock-ss-line { height: 3px; background: var(--gray-700); border-radius: 1px; width: 90%; }
.mock-ss-line--title { width: 70%; background: var(--gray-600); }
.mock-ss-line--short { width: 50%; }
/* Typing animation on screenshare */
.reveal.visible .mock-ss-line { animation: ssTypeIn 0.3s ease forwards; }
.reveal.visible .mock-ss-line:nth-child(1) { animation-delay: 0.3s; opacity: 0; }
.reveal.visible .mock-ss-line:nth-child(2) { animation-delay: 0.6s; opacity: 0; }
.reveal.visible .mock-ss-line:nth-child(3) { animation-delay: 0.9s; opacity: 0; }
@keyframes ssTypeIn {
  from { opacity: 0; width: 0%; }
  to   { opacity: 1; width: 90%; }
}
.mock-self-cam {
  position: absolute; bottom: 0.6rem; right: 0.6rem;
  width: 56px; height: 42px;
  background: var(--gray-800); border: 1px solid var(--gray-700);
  display: flex; align-items: center; justify-content: center;
}
.mock-self-avatar { font-size: 0.65rem; font-weight: 600; color: var(--gray-400); }
.mock-call-controls {
  padding: 0.7rem; display: flex; align-items: center; justify-content: center; gap: 0.8rem;
  border-top: 1px solid var(--gray-800);
}
.mock-ctrl { width: 32px; height: 32px; border-radius: 50%; background: var(--gray-800); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; }
.mock-ctrl--hang { background: #dc2626; color: white; font-size: 0.7rem; font-weight: 700; }
.mock-call-footer { text-align: center; font-size: 0.62rem; color: var(--gray-600); padding: 0.4rem; border-top: 1px solid var(--gray-800); }

/* =====================================================
   MOCKUP 05 — Tienda online (animado)
   ===================================================== */
.mock-store {
  width: 100%; max-width: 320px;
  background: #0d0d0d;
  border: 1px solid var(--gray-800);
  box-shadow: 0 0 40px var(--emp-accent-dim);
  overflow: hidden;
}
.mock-store-header {
  padding: 0.6rem 0.9rem;
  background: #111;
  border-bottom: 1px solid var(--gray-800);
  display: flex; justify-content: space-between; align-items: center;
  font-size: 0.78rem;
}
.mock-store-logo { font-weight: 600; color: var(--emp-accent); }
.mock-cart-icon { font-size: 0.85rem; position: relative; }
.mock-cart-badge {
  position: absolute; top: -4px; right: -6px;
  background: var(--emp-accent); color: white;
  font-size: 0.5rem; font-weight: 700;
  width: 12px; height: 12px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
}
.mock-products {
  display: grid; grid-template-columns: repeat(3,1fr); gap: 1px; background: var(--gray-800);
  padding: 1px;
}
.mock-product {
  background: #0d0d0d;
  padding: 0.6rem 0.5rem;
  display: flex; flex-direction: column; gap: 4px;
  opacity: 0;
}
.reveal.visible .mock-product.p1 { animation: fadeSlideUp 0.4s ease 0.2s forwards; }
.reveal.visible .mock-product.p2 { animation: fadeSlideUp 0.4s ease 0.45s forwards; }
.reveal.visible .mock-product.p3 { animation: fadeSlideUp 0.4s ease 0.7s forwards; }
.mock-product-img { height: 48px; border-radius: 1px; }
.p1 .mock-product-img { background: linear-gradient(135deg, #1a0f00, #2a1500); }
.p2 .mock-product-img { background: linear-gradient(135deg, #0a0f1a, #101820); }
.p3 .mock-product-img { background: linear-gradient(135deg, #0f1a0a, #182a10); }
.mock-product-name { height: 5px; background: var(--gray-700); border-radius: 1px; }
.mock-product-price { font-size: 0.65rem; font-weight: 700; color: var(--white); }
.mock-product-btn {
  font-size: 0.58rem; text-align: center; padding: 0.2rem;
  border: 1px solid var(--gray-700); color: var(--gray-400);
  cursor: default;
}
.mock-product-btn--added {
  border-color: var(--emp-accent); color: var(--emp-accent);
  animation: addedPop 0.3s ease 1s both;
}
.reveal.visible .mock-product-btn--added { animation: addedPop 0.3s ease 1s both; }
@keyframes addedPop {
  0%   { transform: scale(1); }
  50%  { transform: scale(1.08); }
  100% { transform: scale(1); }
}
.mock-store-footer {
  padding: 0.6rem 0.8rem; border-top: 1px solid var(--gray-800);
  display: flex; flex-direction: column; gap: 0.35rem;
}
.mock-payment-icons { display: flex; gap: 0.5rem; align-items: center; }
.mock-pay { font-size: 0.6rem; padding: 0.15rem 0.4rem; border: 1px solid var(--gray-700); color: var(--gray-500); border-radius: 1px; }
.mock-store-wa { font-size: 0.63rem; color: var(--emp-accent); }

/* =====================================================
   MOCKUP 06 — Dashboard reportería (animado)
   ===================================================== */
.mock-dashboard {
