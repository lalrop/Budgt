---
interface Props {
  icon: string;
  title: string;
  description: string;
}

const { icon, title, description } = Astro.props;
---

<div class="feature-card">
  <div class="feature-icon">{icon}</div>
  <h3>{title}</h3>
  <p>{description}</p>
</div>

<style>
  .feature-card {
    background: var(--black);
    padding: 2.5rem 2rem;
    transition: background 0.25s;
  }

  .feature-card:hover {
    background: var(--gray-900);
  }

  .feature-icon {
    font-size: 2rem;
    margin-bottom: 1.4rem;
  }

  .feature-card h3 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: 0.7rem;
  }

  .feature-card p {
    font-size: 0.88rem;
    color: var(--gray-400);
    line-height: 1.65;
    font-weight: 300;
  }
</style>
