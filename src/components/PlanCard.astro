---
interface PlanFeature {
  text: string;
}

interface Props {
  name: string;
  price: string;
  period: string;
  features: PlanFeature[];
  ctaText: string;
  ctaUrl: string;
  featured?: boolean;
  tag?: string;
}

const {
  name,
  price,
  period,
  features,
  ctaText,
  ctaUrl,
  featured = false,
  tag
} = Astro.props;
---

<div class:list={['plan', { featured }]}>
  {tag && <div class="plan-tag">{tag}</div>}
  <div class="plan-price">{price}</div>
  <div class="plan-period">{period}</div>
  <ul class="plan-features">
    {features.map((feature) => (
      <li>
        <span class="arrow">→</span>
        {feature.text}
      </li>
    ))}
  </ul>
  <a href={ctaUrl} class="plan-btn" target="_blank" rel="noopener">
    {ctaText}
  </a>
</div>

<style>
  .plan {
    background: var(--gray-900);
    padding: 2.5rem 2rem;
    position: relative;
  }

  .plan.featured {
    background: var(--white);
    color: var(--black);
  }

  .plan-tag {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--gray-400);
    margin-bottom: 1.5rem;
  }

  .plan.featured .plan-tag {
    color: #777777;
  }

  .plan-price {
    font-family: var(--font-serif);
    font-size: 2.8rem;
    letter-spacing: -0.03em;
    line-height: 1;
    margin-bottom: 0.3rem;
  }

  .plan-period {
    font-size: 0.82rem;
    color: var(--gray-500);
    margin-bottom: 2rem;
    font-weight: 300;
  }

  .plan.featured .plan-period {
    color: #888888;
  }

  .plan-features {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    margin-bottom: 2.2rem;
  }

  .plan-features li {
    font-size: 0.88rem;
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    line-height: 1.45;
    color: var(--gray-400);
    font-weight: 300;
  }

  .plan.featured .plan-features li {
    color: #444444;
  }

  .arrow {
    color: var(--gray-600);
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .plan.featured .arrow {
    color: #888888;
  }

  .plan-btn {
    display: block;
    text-align: center;
    padding: 0.85rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-decoration: none;
    border: 1px solid var(--gray-800);
    color: var(--white);
    transition: border-color 0.2s;
  }

  .plan-btn:hover {
    border-color: var(--gray-600);
  }

  .plan.featured .plan-btn {
    background: var(--black);
    color: var(--white);
    border-color: var(--black);
  }

  .plan.featured .plan-btn:hover {
    background: var(--gray-800);
  }
</style>
