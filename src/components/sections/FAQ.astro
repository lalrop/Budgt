---
import type { FAQItem } from '../../data/faq';

interface Props {
  items: FAQItem[];
  label?: string;
  title?: string;
}

const {
  items,
  label = 'Preguntas frecuentes',
  title = 'Todo lo que necesitas saber',
} = Astro.props;
---

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": items.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
})} />

<section class="product-section faq-section" id="faq">
  <div class="container">
    <span class="section-label">{label}</span>
    <h2 class="faq-title reveal">{title}</h2>

    <div class="faq-list">
      {items.map((item, i) => (
        <div class="faq-item reveal" data-index={i}>
          <button class="faq-q" aria-expanded="false">
            <span>{item.q}</span>
            <svg class="faq-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M4 7l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="faq-a">
            <p>{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-title {
    font-family: var(--font-serif);
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    color: var(--white);
    margin-bottom: 2.5rem;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--gray-800);
  }

  .faq-item { border-bottom: 1px solid var(--gray-800); }

  .faq-q {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 1.4rem 0;
    text-align: left;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--white);
    font-family: var(--font-sans);
    transition: color var(--transition);
  }
  .faq-q:hover { color: var(--gray-400); }

  .faq-icon {
    flex-shrink: 0;
    color: var(--gray-600);
    transition: transform 0.25s ease;
  }
  .faq-item.open .faq-icon { transform: rotate(180deg); }

  .faq-a {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }
  .faq-item.open .faq-a { max-height: 300px; }

  .faq-a p {
    font-size: 0.88rem;
    color: var(--gray-600);
    line-height: 1.65;
    padding-bottom: 1.4rem;
  }
</style>

<script>
  document.querySelectorAll('.faq-item').forEach((item) => {
    const btn = item.querySelector('.faq-q') as HTMLButtonElement;
    btn?.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach((i) => {
        i.classList.remove('open');
        (i.querySelector('.faq-q') as HTMLButtonElement)?.setAttribute('aria-expanded', 'false');
      });
      if (!isOpen) {
        item.classList.add('open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
