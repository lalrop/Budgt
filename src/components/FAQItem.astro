---
interface Props {
  question: string;
  answer: string;
}

const { question, answer } = Astro.props;
---

<div class="faq-item">
  <div class="faq-q">
    <span>{question}</span>
    <span class="faq-arrow">+</span>
  </div>
  <div class="faq-a">
    <p>{answer}</p>
  </div>
</div>

<script>
  document.querySelectorAll('.faq-item').forEach((item) => {
    const questionEl = item.querySelector('.faq-q');
    questionEl?.addEventListener('click', () => {
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach((i) => i.classList.remove('open'));
      if (!isOpen) {
        item.classList.add('open');
      }
    });
  });
</script>

<style>
  .faq-item {
    border-top: 1px solid var(--gray-800);
    padding: 1.6rem 0;
  }

  .faq-q {
    font-size: 0.98rem;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 0.7rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .faq-arrow {
    font-size: 1.1rem;
    color: var(--gray-700);
    flex-shrink: 0;
    transition: transform 0.25s;
  }

  .faq-item.open .faq-arrow {
    transform: rotate(45deg);
  }

  .faq-a {
    font-size: 0.88rem;
    color: var(--gray-400);
    line-height: 1.7;
    font-weight: 300;
    max-height: 0;
    overflow: hidden;
    transition:
      max-height 0.35s ease,
      opacity 0.3s;
    opacity: 0;
  }

  .faq-item.open .faq-a {
    max-height: 400px;
    opacity: 1;
  }

  .faq-a p {
    margin-bottom: 0;
  }
</style>
